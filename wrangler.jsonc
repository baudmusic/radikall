{
  "$schema": "./webApp/node_modules/wrangler/config-schema.json",
  "name": "radikall-web",
  "main": "./webApp/worker/src/index.ts",
  "compatibility_date": "2025-04-24",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "directory": "./webApp/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/health"]
  }
}
